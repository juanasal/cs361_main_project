<!DOCTYPE html>
<html>

<head>
  <title>Home</title>
  <link rel="stylesheet" href="/style.css">
</head>

<body>
  <main class="dashboard-shell">
    <section class="dashboard-panel">
      <header class="dashboard-header">
        <h1>PostLingo!</h1>

        <nav class="dashboard-nav" aria-label="Dashboard navigation">
          <button type="button">Play Game</button>
          <button type="button">Read Article</button>
          <button type="button" class="active">Dashboard</button>
          <form method="POST" action="/logout">
            <button type="submit">Log Out</button>
          </form>
        </nav>
      </header>

      <section class="stats-readout" aria-label="Dashboard stats">
        <p>Logged in as <strong><%= username %></strong>.</p>
        <p>Games Completed: <strong><%= stats.gamesCompleted %></strong></p>
        <p>Average Game Score: <strong><%= stats.averageGameScore %></strong></p>
        <p>Readings Completed: <strong><%= stats.readingsCompleted %></strong></p>
        <p>Average Quiz Score: <strong><%= stats.averageQuizScore %></strong></p>
      </section>
    </section>
  </main>
</body>

</html>
